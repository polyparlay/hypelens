# PolyParlay X auto-poster credentials
# Copy this file to .env and fill in your X API keys.
#
# How to get these:
#   1. https://developer.x.com → sign up (free tier)
#   2. Create a Project + App
#   3. App settings → "User authentication settings":
#        - Type: Read and write
#        - Type of App: Automated App or Bot (or "Web App")
#        - Callback URI: https://polyparlay.app (anything works for our flow)
#   4. App → "Keys and tokens" tab:
#        - "API Key and Secret" → that's X_API_KEY + X_API_SECRET
#        - "Access Token and Secret" → click Generate → that's X_ACCESS_TOKEN + X_ACCESS_SECRET
#   5. Paste below.

X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_SECRET=
