{
  "manifest_version": 3,
  "name": "HypeLens \u2014 Liquidation Heatmap & Smart Money (Module 3 / testnet)",
  "version": "0.22.0",
  "description": "PHASE-2 build: read-only heatmap + opt-in one-click order placement (agent wallet + builder code, TESTNET only). To enable Module 3, copy this file over manifest.json.",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://api.hyperliquid.xyz/*",
    "https://api.hyperliquid-testnet.xyz/*",
    "https://raw.githubusercontent.com/*"
  ],
  "action": {
    "default_popup": "popup.module3.html",
    "default_title": "HypeLens",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://app.hyperliquid.xyz/*"
      ],
      "js": [
        "exchange/hl-secret.js"
      ],
      "run_at": "document_start"
    },
    {
      "matches": [
        "https://app.hyperliquid.xyz/*"
      ],
      "js": [
        "viewmodel.js",
        "vendor/lightweight-charts.standalone.production.js",
        "hud.js",
        "vendor/hl-sdk.js",
        "exchange/hl-actions.js",
        "exchange/hl-vault.js",
        "exchange/hl-signer.js",
        "exchange/hl-eth-bridge.js",
        "exchange/hl-place.js",
        "exchange/place-ui.js",
        "content.js"
      ],
      "css": [
        "content.css"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://app.hyperliquid.xyz/*"
      ],
      "js": [
        "inject-eth-main.js"
      ],
      "world": "MAIN",
      "run_at": "document_start"
    }
  ]
}